{
  "name": "agriprice-backend",
  "version": "1.0.0",
  "description": "Backend API for Agricultural Price Tracking System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore scraped/ --ignore scraped/all_regions.json server.js",
    "db:init": "node db.js",
    "db:clear": "node db-clear.js",
    "ai:check": "node scripts/check_ai_provider.mjs",
    "price:backfill": "node scripts/backfill_price_history.mjs",
    "source:seed": "node scripts/seed_source_info.mjs"
  },
  "keywords": [
    "agriculture",
    "price-tracking",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@payos/node": "^2.0.5",
    "axios": "^1.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.15.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "openai": "^6.9.1",
    "puppeteer": "^24.26.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
